# .env.example
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# --- Database ---
# Local development (via Supabase connection pooler):
# DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_REF:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres
#
# Production (same URL — Supabase is the DB in both environments):
# DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_REF:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_REF:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_to_a_random_32_char_hex_string

# --- Environment ---
# "development" enables Swagger UI, allows all CORS origins, sets log level INFO.
# "production" disables Swagger UI, enforces CORS_ORIGINS list, sets log level WARNING.
ENVIRONMENT=development

# --- Supabase Storage ---
# Found in: Supabase Dashboard > Settings > API
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_KEY=your-service-role-key-here

# Name of the storage bucket created in Supabase Dashboard > Storage
SUPABASE_BUCKET=facturas

# Maximum image upload size in megabytes
MAX_UPLOAD_SIZE_MB=10

# --- CORS (production only) ---
# Comma-separated list of allowed frontend origins.
# Only used when ENVIRONMENT=production.
# Example: https://myapp.vercel.app,https://admin.myapp.com
# Leave empty to block all cross-origin requests.
CORS_ORIGINS=
